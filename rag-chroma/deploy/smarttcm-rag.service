[Unit]
Description=SmartTCM RAG API
After=network-online.target docker.service
Wants=network-online.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/SmartTCM/rag
EnvironmentFile=/home/pi/SmartTCM/rag/.env
ExecStart=/home/pi/SmartTCM/rag/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8094
Restart=always
RestartSec=5
StandardOutput=append:/home/pi/SmartTCM/data/results/rag_api.log
StandardError=append:/home/pi/SmartTCM/data/results/rag_api.log

[Install]
WantedBy=multi-user.target
