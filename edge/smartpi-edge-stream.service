[Unit]
Description=smartpi Raspberry Pi MJPEG Detection Stream
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/smartpi
EnvironmentFile=-/home/pi/smartpi/config/mjpeg_stream.env
ExecStart=/home/pi/smartpi/edge/pi_run_mjpeg_stream.sh
Restart=always
RestartSec=3
StandardOutput=append:/home/pi/smartpi/data/results/mjpeg_stream.log
StandardError=append:/home/pi/smartpi/data/results/mjpeg_stream.log

[Install]
WantedBy=multi-user.target
