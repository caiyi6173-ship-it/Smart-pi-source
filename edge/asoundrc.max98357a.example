# Example ALSA user config for MAX98357A on Raspberry Pi.
# Copy to: /home/pi/.asoundrc

pcm.!default {
  type asym
  playback.pcm "speaker"
  capture.pcm "mic"
}

pcm.speaker {
  type plug
  slave.pcm "hw:0,0"
}

pcm.mic {
  type plug
  slave.pcm "sysdefault"
}

ctl.!default {
  type hw
  card 0
}
