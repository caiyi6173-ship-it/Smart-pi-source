# Copy to /home/pi/smartpi/config/voice_agent.env when deploying on Raspberry Pi.
BRIDGE_BASE_URL=http://127.0.0.1:8092
WAKE_WORD=小中医
ASSISTANT_NAME=smartpi Voice
RECORD_DEVICE=default
PLAYBACK_DEVICE=default
RECORD_SECONDS=3
RECORD_SAMPLE_RATE=16000
ENABLE_LOCAL_STT=1
FASTER_WHISPER_MODEL=tiny
FASTER_WHISPER_DEVICE=cpu
FASTER_WHISPER_COMPUTE_TYPE=int8
FASTER_WHISPER_LANGUAGE=zh
FASTER_WHISPER_INITIAL_PROMPT=smartpi 舌象分析、摄像头识别、心率、血氧、皮肤温度、读取分析结果、重新分析。
FASTER_WHISPER_WAKE_MODEL=tiny
FASTER_WHISPER_WAKE_COMPUTE_TYPE=int8
FASTER_WHISPER_WAKE_INITIAL_PROMPT=
HF_ENDPOINT=https://hf-mirror.com
HF_HOME=/home/pi/smartpi/cache/huggingface
ENABLE_LOCAL_TTS=1
PIPER_COMMAND=/home/pi/smartpi/venv/bin/python -m piper
PIPER_MODEL_PATH=/home/pi/smartpi/models/piper/zh_CN-huayan-medium.onnx
PIPER_CONFIG_PATH=/home/pi/smartpi/models/piper/zh_CN-huayan-medium.onnx.json
TTS_CACHE_DIR=/home/pi/smartpi/cache/tts
ENABLE_WEBRTCVAD=1
VAD_MODE=1
VAD_FRAME_MS=30
ENABLE_WAKE_LISTEN=1
ENABLE_KEYWORD_SPOTTER=0
WAKE_LISTEN_WINDOW_SECONDS=1.8
COMMAND_MAX_RECORD_SECONDS=3
COMMAND_SILENCE_STOP_MS=700
COMMAND_MIN_SPEECH_MS=300
COMMAND_RMS_THRESHOLD=220
WAKE_RMS_THRESHOLD=160
WAKE_LISTEN_COOLDOWN_SECONDS=0.25
WAKE_WORD_ALIASES=小芳,小房,晓方
WAKE_FUZZY_MAX_DISTANCE=1
WAKE_FUZZY_PREFIX_WINDOW_CHARS=8
SHERPA_KWS_COMMAND=/home/pi/smartpi/venv/bin/sherpa-onnx-keyword-spotter
SHERPA_KWS_CLI=/home/pi/smartpi/venv/bin/sherpa-onnx-cli
SHERPA_KWS_MODEL_DIR=/home/pi/smartpi/models/kws/sherpa-onnx-kws-zipformer-wenetspeech-3.3M-2024-01-01
SHERPA_KWS_TOKENS_TYPE=
SHERPA_KWS_KEYWORDS_THRESHOLD=0.35
SHERPA_KWS_KEYWORDS_SCORE=1.8
SHERPA_KWS_NUM_THREADS=2
WAKE_ACK_TEXT=
PORT=8093
ENABLE_CLOUD_SPEECH=0
DASHSCOPE_API_KEY=
DASHSCOPE_ASR_MODEL=paraformer-realtime-v2
DASHSCOPE_TTS_MODEL=cosyvoice-v2
DASHSCOPE_TTS_VOICE=longxiaochun_v2
ENABLE_DIRECT_LLM=0
DIRECT_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
DIRECT_LLM_API_KEY=
DIRECT_LLM_MODEL=qwen3-vl-flash-2026-01-22
DIRECT_LLM_TIMEOUT_SECONDS=20
DIRECT_LLM_TEMPERATURE=0.2
ENABLE_OPENCLAW=1
OPENCLAW_TIMEOUT_SECONDS=12
OPENCLAW_COMMAND=/home/pi/smartpi/openclaw/run_openclaw_message.sh {text}
ENABLE_AGENT_ORCHESTRATOR=0
AGENT_ORCHESTRATOR_URL=http://127.0.0.1:8096
AGENT_ORCHESTRATOR_TIMEOUT_SECONDS=30
